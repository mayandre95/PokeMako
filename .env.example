# .env.example

# -- PostgreSQL --
POSTGRES_USER=pokemako
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pokemako_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pokemako:changeme@db:5432/pokemako_db

# -- Redis --
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# -- FastAPI --
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=changeme_secret_key

# -- Frontend --
VITE_API_URL=http://localhost:8000

# -- MLflow / Dagshub --
MLFLOW_TRACKING_URI=https://dagshub.com/<username>/pokemako.mlflow
DAGSHUB_USERNAME=<username>
DAGSHUB_TOKEN=changeme
